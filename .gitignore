# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.idea
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .env.example, ignore the rest)
.env*.local
.env
.env.production

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# content inbox (contact form fallback)
content/inbox/*.json
!content/inbox/.gitkeep

# raw image sources (kept in separate cloud backup)
_raw/
/resources