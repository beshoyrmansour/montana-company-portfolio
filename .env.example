# ─────────────────────────────────────────────────────────────────
# Montana Website — Environment Variables
# Full reference: docs/reference/env-vars.md
#
# Copy to .env.local for dev. Set in Vercel → Project Settings → Environment
# Variables for staging + prod.
# NEXT_PUBLIC_* are exposed to the browser bundle; everything else is server-only.
# ─────────────────────────────────────────────────────────────────

# ── Site identity ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Theme (one of: default | ramadan | christmas) ──
NEXT_PUBLIC_THEME=default
NEXT_PUBLIC_THEME_GREETING_ENABLED=true

# ── i18n ──
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_AVAILABLE_LOCALES=en,ar,fr

# ── Feature flags ──
NEXT_PUBLIC_HIDDEN_PAGES=
NEXT_PUBLIC_SEARCH_ENABLED=true
NEXT_PUBLIC_NEWSLETTER_ENABLED=false
NEXT_PUBLIC_COOKIE_BANNER_ENABLED=true

# ── Analytics (optional — leave empty to disable) ──
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# ── Contact form (server-only / Cloudflare Pages Function) ──
RESEND_API_KEY=
RESEND_REGION=eu-west-1
CONTACT_FROM_EMAIL=noreply@montanaeg.com
CONTACT_TO_EMAIL=sales@montanaeg.com
CONTACT_CC_EMAIL=
CONTACT_RATE_LIMIT_PER_HOUR=5

# ── Anti-spam (Cloudflare Turnstile) ──
# Get keys: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ── Maps ──
NEXT_PUBLIC_MAP_PROVIDER=static
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_FACTORY_LAT=30.2156
NEXT_PUBLIC_FACTORY_LNG=31.2089

# ── Maintenance ──
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="We're upgrading the site. Back shortly."

# ── Build flags ──
ANALYZE=false
